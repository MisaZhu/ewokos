#ifndef EWOK_STL_ITERATOR_H
#define EWOK_STL_ITERATOR_H

#include <cstddef>

namespace std {

// Define our own iterator tags
struct input_iterator_tag {};
struct output_iterator_tag {};
struct forward_iterator_tag : input_iterator_tag {};
struct bidirectional_iterator_tag : forward_iterator_tag {};
struct random_access_iterator_tag : bidirectional_iterator_tag {};

// Forward declaration of iterator_traits
template <typename Iterator>
struct iterator_traits;

template <typename T>
class base_iterator {
    public:
        typedef T value_type;
        typedef ptrdiff_t difference_type;
        typedef T* pointer;
        typedef T& reference;
        typedef input_iterator_tag iterator_category;

        base_iterator() : ptr_(nullptr) {}
        base_iterator(T* ptr) : ptr_(ptr) {}
        base_iterator(const base_iterator& src) : ptr_(src.ptr_) {}

        base_iterator& operator=(const base_iterator& rhs) {
            ptr_ = rhs.ptr_;
            return *this;
        }

        base_iterator& operator++() {
            ++ptr_;
            return *this;
        }

        base_iterator operator++(int) {
            base_iterator tmp(*this);
            ++ptr_;
            return tmp;
        }

        bool operator==(const base_iterator& rhs) const { return ptr_ == rhs.ptr_; }
        bool operator!=(const base_iterator& rhs) const { return ptr_ != rhs.ptr_; }

        T& operator*() { return *ptr_; }
        const T& operator*() const { return *ptr_; }
        T* operator->() { return ptr_; }
        const T* operator->() const { return ptr_; }

        T* base() const { return ptr_; }

    protected:
        T* ptr_;
};

template <typename T>
class bidirectionnal_iterator : public base_iterator<T> {
    public:
        using base_iterator<T>::ptr_;
        typedef bidirectional_iterator_tag iterator_category;

        bidirectionnal_iterator() : base_iterator<T>() {}
        bidirectionnal_iterator(T* ptr) : base_iterator<T>(ptr) {}
        bidirectionnal_iterator(const bidirectionnal_iterator& src) : base_iterator<T>(src) {}

        bidirectionnal_iterator& operator=(const bidirectionnal_iterator& rhs) {
            this->ptr_ = rhs.ptr_;
            return *this;
        }

        bidirectionnal_iterator& operator++() {
            ++this->ptr_;
            return *this;
        }

        bidirectionnal_iterator operator++(int) {
            bidirectionnal_iterator tmp(*this);
            ++this->ptr_;
            return tmp;
        }

        bidirectionnal_iterator& operator--() {
            --this->ptr_;
            return *this;
        }

        bidirectionnal_iterator operator--(int) {
            bidirectionnal_iterator tmp(*this);
            --this->ptr_;
            return tmp;
        }
};

template <typename T>
class random_access_iterator : public bidirectionnal_iterator<T> {
    public:
        using bidirectionnal_iterator<T>::ptr_;
        typedef random_access_iterator_tag iterator_category;

        random_access_iterator() : bidirectionnal_iterator<T>() {}
        random_access_iterator(T* ptr) : bidirectionnal_iterator<T>(ptr) {}
        random_access_iterator(const random_access_iterator& src) : bidirectionnal_iterator<T>(src) {}

        random_access_iterator& operator=(const random_access_iterator& rhs) {
            this->ptr_ = rhs.ptr_;
            return *this;
        }

        random_access_iterator& operator++() {
            ++this->ptr_;
            return *this;
        }

        random_access_iterator operator++(int) {
            random_access_iterator tmp(*this);
            ++this->ptr_;
            return tmp;
        }

        random_access_iterator& operator--() {
            --this->ptr_;
            return *this;
        }

        random_access_iterator operator--(int) {
            random_access_iterator tmp(*this);
            --this->ptr_;
            return tmp;
        }

        random_access_iterator operator+(ptrdiff_t n) const {
            return random_access_iterator(this->ptr_ + n);
        }

        random_access_iterator operator-(ptrdiff_t n) const {
            return random_access_iterator(this->ptr_ - n);
        }

        ptrdiff_t operator-(const random_access_iterator& rhs) const {
            return this->ptr_ - rhs.ptr_;
        }

        bool operator<(const random_access_iterator& rhs) const { return this->ptr_ < rhs.ptr_; }
        bool operator>(const random_access_iterator& rhs) const { return this->ptr_ > rhs.ptr_; }
        bool operator<=(const random_access_iterator& rhs) const { return this->ptr_ <= rhs.ptr_; }
        bool operator>=(const random_access_iterator& rhs) const { return this->ptr_ >= rhs.ptr_; }

        random_access_iterator& operator+=(ptrdiff_t n) { this->ptr_ += n; return *this; }
        random_access_iterator& operator-=(ptrdiff_t n) { this->ptr_ -= n; return *this; }

        T& operator[](ptrdiff_t n) { return *(this->ptr_ + n); }
        const T& operator[](ptrdiff_t n) const { return *(this->ptr_ + n); }
};

template <typename T>
random_access_iterator<T> operator+(ptrdiff_t n, const random_access_iterator<T>& rhs) {
    return rhs + n;
}

// iterator_traits specializations
template <typename T>
struct iterator_traits<base_iterator<T>> {
    typedef typename base_iterator<T>::difference_type difference_type;
    typedef typename base_iterator<T>::value_type value_type;
    typedef typename base_iterator<T>::pointer pointer;
    typedef typename base_iterator<T>::reference reference;
    typedef typename base_iterator<T>::iterator_category iterator_category;
};

template <typename T>
struct iterator_traits<bidirectionnal_iterator<T>> {
    typedef typename bidirectionnal_iterator<T>::difference_type difference_type;
    typedef typename bidirectionnal_iterator<T>::value_type value_type;
    typedef typename bidirectionnal_iterator<T>::pointer pointer;
    typedef typename bidirectionnal_iterator<T>::reference reference;
    typedef typename bidirectionnal_iterator<T>::iterator_category iterator_category;
};

template <typename T>
struct iterator_traits<random_access_iterator<T>> {
    typedef typename random_access_iterator<T>::difference_type difference_type;
    typedef typename random_access_iterator<T>::value_type value_type;
    typedef typename random_access_iterator<T>::pointer pointer;
    typedef typename random_access_iterator<T>::reference reference;
    typedef typename random_access_iterator<T>::iterator_category iterator_category;
};

}

#endif
