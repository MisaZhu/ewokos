#ifndef EWOK_STL_DEQUE_H
#define EWOK_STL_DEQUE_H

#include "iterator"

#include <stddef.h>
#include <stdlib.h>
#include <string.h>

namespace std {

template <typename T>
class deque {
    public:
        typedef T value_type;
        typedef T& reference;
        typedef const T& const_reference;
        typedef size_t size_type;
        typedef random_access_iterator<T> iterator;
        typedef const random_access_iterator<T> const_iterator;

        deque() : data_(nullptr), size_(0), capacity_(0) {}

        deque(size_t n, const T& val=T()) : data_(nullptr), size_(0), capacity_(0) {
            for (size_t i = 0; i < n; ++i) {
                push_back(val);
            }
        }

        deque(const deque<T>& src) : data_(nullptr), size_(0), capacity_(0) {
            for (size_t i = 0; i < src.size_; ++i) {
                push_back(src.data_[i]);
            }
        }

        ~deque() {
            clear();
            if (data_) {
                free(data_);
            }
        }

        deque<T>& operator=(const deque& rhs) {
            if (this != &rhs) {
                clear();
                for (size_t i = 0; i < rhs.size_; ++i) {
                    push_back(rhs.data_[i]);
                }
            }
            return *this;
        }

        iterator begin() { return iterator(data_); }
        const_iterator begin() const { return const_iterator(data_); }
        iterator end() { return iterator(data_ + size_); }
        const_iterator end() const { return const_iterator(data_ + size_); }

        T& operator[](size_t n) { return data_[n]; }
        const T& operator[](size_t n) const { return data_[n]; }
        T& at(size_t n) { return data_[n]; }
        const T& at(size_t n) const { return data_[n]; }

        T& front() { return data_[0]; }
        const T& front() const { return data_[0]; }
        T& back() { return data_[size_ - 1]; }
        const T& back() const { return data_[size_ - 1]; }

        size_t size() const { return size_; }
        bool empty() const { return size_ == 0; }

        void resize(size_t n, T val=T()) {
            while (size_ > n) {
                pop_back();
            }
            while (size_ < n) {
                push_back(val);
            }
        }

        void push_front(const T& val) {
            if (size_ >= capacity_) {
                reserve(capacity_ == 0 ? 16 : capacity_ * 2);
            }
            // Move existing elements using placement new and copy
            for (size_t i = size_; i > 0; --i) {
                new (&data_[i]) T(data_[i-1]);
                data_[i-1].~T();
            }
            // Construct new element
            new (&data_[0]) T(val);
            ++size_;
        }

        void pop_front() {
            if (size_ > 0) {
                // Destroy first element
                data_[0].~T();
                // Move remaining elements
                for (size_t i = 0; i < size_ - 1; ++i) {
                    new (&data_[i]) T(data_[i+1]);
                    data_[i+1].~T();
                }
                --size_;
            }
        }

        void push_back(const T& val) {
            if (size_ >= capacity_) {
                reserve(capacity_ == 0 ? 16 : capacity_ * 2);
            }
            // Use placement new to construct element in place
            new (&data_[size_]) T(val);
            ++size_;
        }

        void pop_back() {
            if (size_ > 0) {
                // Destroy last element
                data_[size_ - 1].~T();
                --size_;
            }
        }

        void clear() {
            // Destroy all elements
            for (size_t i = 0; i < size_; ++i) {
                data_[i].~T();
            }
            size_ = 0;
        }

    private:
        T* data_;
        size_t size_;
        size_t capacity_;

        void reserve(size_t n) {
            if (n > capacity_) {
                T* new_data = (T*)malloc(n * sizeof(T));
                // Move existing elements using placement new
                for (size_t i = 0; i < size_; ++i) {
                    new (&new_data[i]) T(data_[i]);
                    data_[i].~T();
                }
                if (data_) {
                    free(data_);
                }
                data_ = new_data;
                capacity_ = n;
            }
        }
};

}

#endif
