#ifndef EWOK_STL_UNORDERED_SET_H
#define EWOK_STL_UNORDERED_SET_H

#include "iterator"

#include <stddef.h>

namespace std {

template <typename T>
struct unordered_set_node {
    T key;
    unordered_set_node* next;

    unordered_set_node(const T& k) : key(k), next(nullptr) {}
};

template <typename T>
class unordered_set {
    public:
        typedef T value_type;
        typedef T& reference;
        typedef const T& const_reference;
        typedef size_t size_type;
        typedef random_access_iterator<T> iterator;
        typedef const random_access_iterator<T> const_iterator;

        unordered_set();
        unordered_set(const unordered_set<T>& src);
        ~unordered_set();

        unordered_set<T>& operator=(const unordered_set& rhs);

        iterator begin();
        const_iterator begin() const;
        iterator end();
        const_iterator end() const;

        size_t size() const;
        bool empty() const;

        void clear();

        iterator find(const T& val);
        const_iterator find(const T& val) const;

        size_t insert(const T& val);
        size_t erase(const T& val);

        void swap(unordered_set& other);

    private:
        static const size_t BUCKET_COUNT = 32;

        unordered_set_node<T>** buckets_;
        size_t size_;

        size_t hash(const T& val) const;
        void rehash();
};

}

#endif