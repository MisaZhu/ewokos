// bad_weak_ptr exception class
class bad_weak_ptr : public exception {
public:
    bad_weak_ptr() noexcept {}
    ~bad_weak_ptr() noexcept override {}
    const char* what() const noexcept override {
        return "bad_weak_ptr";
