// Non-template base control block for type erasure
class __shared_ptr_control_block_base {
protected:
    size_t strong_count_;
    size_t weak_count_;
    
    __shared_ptr_control_block_base() : strong_count_(1), weak_count_(0) {}
    virtual ~__shared_ptr_control_block_base() {}
    
    void add_strong() { ++strong_count_; }
    void add_weak() { ++weak_count_; }
    
    void release_strong() {
        if (--strong_count_ == 0) {
            destroy_object();
            if (weak_count_ == 0) {
                delete_self();
            }
        }
    }

    void release_weak() {
        if (--weak_count_ == 0 && strong_count_ == 0) {
            delete_self();
        }
    }
    
    bool expired() const {
        return strong_count_ == 0;
    }
    
    size_t use_count() const {
        return strong_count_;
    }
    
    virtual void destroy_object() = 0;
    virtual void delete_self() = 0;
    
    template <typename U> friend class shared_ptr;
    template <typename U> friend class weak_ptr;
};

// Template control block
template <typename T, typename Deleter = default_delete<T>>
class __shared_ptr_control_block : public __shared_ptr_control_block_base {
public:
    __shared_ptr_control_block(T* ptr, Deleter d = Deleter()) : ptr_(ptr), deleter_(d) {}
    
    virtual void destroy_object() override {
        if (ptr_) {
            deleter_(ptr_);
            ptr_ = nullptr;
        }
    }
    
    virtual void delete_self() override {
        delete this;
    }
    
    T* get_ptr() const { return ptr_; }
    Deleter& get_deleter() { return deleter_; }
    const Deleter& get_deleter() const { return deleter_; }
    
private:
    T* ptr_;
    Deleter deleter_;
    
    template <typename U, typename D> friend class __shared_ptr_control_block;
};

// weak_ptr definition (before shared_ptr)
template <typename T>
class weak_ptr {
    public:
        typedef T element_type;

        constexpr weak_ptr() noexcept : ptr_(nullptr), control_block_(nullptr) {}

        weak_ptr(const shared_ptr<T>& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_weak();
            }
        }

        weak_ptr(const weak_ptr& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_weak();
            }
        }

        template <typename U>
        weak_ptr(const shared_ptr<U>& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_weak();
            }
        }

        template <typename U>
        weak_ptr(const weak_ptr<U>& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_weak();
            }
        }

        weak_ptr(weak_ptr&& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
        }

        template <typename U>
        weak_ptr(weak_ptr<U>&& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
        }

        ~weak_ptr() {
            if (control_block_) {
                control_block_->release_weak();
            }
        }

        weak_ptr& operator=(const weak_ptr& other) noexcept {
            if (this != &other) {
                if (control_block_) {
                    control_block_->release_weak();
                }
                ptr_ = other.ptr_;
                control_block_ = other.control_block_;
                if (control_block_) {
                    control_block_->add_weak();
                }
            }
            return *this;
        }

        template <typename U>
        weak_ptr& operator=(const weak_ptr<U>& other) noexcept {
            if (control_block_) {
                control_block_->release_weak();
            }
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            if (control_block_) {
                control_block_->add_weak();
            }
            return *this;
        }

        template <typename U>
        weak_ptr& operator=(const shared_ptr<U>& other) noexcept {
            if (control_block_) {
                control_block_->release_weak();
            }
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            if (control_block_) {
                control_block_->add_weak();
            }
            return *this;
        }

        weak_ptr& operator=(weak_ptr&& other) noexcept {
            if (control_block_) {
                control_block_->release_weak();
            }
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
            return *this;
        }

        template <typename U>
        weak_ptr& operator=(weak_ptr<U>&& other) noexcept {
            if (control_block_) {
                control_block_->release_weak();
            }
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
            return *this;
        }

        void reset() noexcept {
            if (control_block_) {
                control_block_->release_weak();
            }
            ptr_ = nullptr;
            control_block_ = nullptr;
        }

        void swap(weak_ptr& other) noexcept {
            T* tmp_ptr = ptr_;
            __shared_ptr_control_block_base* tmp_ctrl = control_block_;
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            other.ptr_ = tmp_ptr;
            other.control_block_ = tmp_ctrl;
        }

        shared_ptr<T> lock() const noexcept;

        long use_count() const noexcept {
            return control_block_ ? static_cast<long>(control_block_->use_count()) : 0;
        }

        bool expired() const noexcept {
            return control_block_ == nullptr || control_block_->expired();
        }

        template <typename U>
        bool owner_before(const shared_ptr<U>& other) const noexcept {
            return control_block_ < other.control_block_;
        }

        template <typename U>
        bool owner_before(const weak_ptr<U>& other) const noexcept {
            return control_block_ < other.control_block_;
        }

    private:
        T* ptr_;
        __shared_ptr_control_block_base* control_block_;

        template <typename U> friend class shared_ptr;
};

// shared_ptr definition
template <typename T>
class shared_ptr {
    public:
        typedef T element_type;

        // Default constructor
        constexpr shared_ptr() noexcept : ptr_(nullptr), control_block_(nullptr) {}

        // nullptr constructor
        constexpr shared_ptr(nullptr_t) noexcept : ptr_(nullptr), control_block_(nullptr) {}

        // Constructor from raw pointer
        template <typename U, typename enable_if<!is_array<U>::value, int>::type = 0>
        explicit shared_ptr(U* p) : ptr_(p), control_block_(nullptr) {
            if (p != nullptr) {
                control_block_ = new __shared_ptr_control_block<U>(p);
                // Initialize enable_shared_from_this
                __try_init_enable_shared_from_this(*this, p);
            }
        }

        // Constructor with deleter
        template <typename U, typename D, typename enable_if<!is_array<U>::value, int>::type = 0>
        shared_ptr(U* p, D d) : ptr_(p), control_block_(nullptr) {
            if (p != nullptr) {
                control_block_ = new __shared_ptr_control_block<U, D>(p, d);
            }
        }

        // Copy constructor
        shared_ptr(const shared_ptr& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_strong();
            }
        }

        // Move constructor
        shared_ptr(shared_ptr&& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
        }

        // Aliasing constructor
        template <typename U>
        shared_ptr(const shared_ptr<U>& other, T* p) noexcept : ptr_(p), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_strong();
            }
        }

        // Copy constructor from compatible type
        template <typename U>
        shared_ptr(const shared_ptr<U>& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            if (control_block_) {
                control_block_->add_strong();
            }
        }

        // Move constructor from compatible type
        template <typename U>
        shared_ptr(shared_ptr<U>&& other) noexcept : ptr_(other.ptr_), control_block_(other.control_block_) {
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
        }

        // Constructor from weak_ptr
        explicit shared_ptr(const weak_ptr<T>& w) : ptr_(nullptr), control_block_(nullptr) {
            if (w.expired()) {
                return;
            }
            ptr_ = w.ptr_;
            control_block_ = w.control_block_;
            if (control_block_) {
                control_block_->add_strong();
            }
        }

        ~shared_ptr() {
            if (control_block_) {
                control_block_->release_strong();
                control_block_ = nullptr;
            }
            ptr_ = nullptr;
        }

        // Copy assignment
        shared_ptr& operator=(const shared_ptr& other) noexcept {
            if (this != &other) {
                shared_ptr(other).swap(*this);
            }
            return *this;
        }

        // Move assignment
        shared_ptr& operator=(shared_ptr&& other) noexcept {
            if (this != &other) {
                release();
                ptr_ = other.ptr_;
                control_block_ = other.control_block_;
                other.ptr_ = nullptr;
                other.control_block_ = nullptr;
            }
            return *this;
        }

        // Copy assignment from compatible type
        template <typename U>
        shared_ptr& operator=(const shared_ptr<U>& other) noexcept {
            shared_ptr<U>(other).swap(*this);
            return *this;
        }

        // Move assignment from compatible type
        template <typename U>
        shared_ptr& operator=(shared_ptr<U>&& other) noexcept {
            release();
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            other.ptr_ = nullptr;
            other.control_block_ = nullptr;
            return *this;
        }

        // Reset
        void reset() noexcept {
            release();
            ptr_ = nullptr;
            control_block_ = nullptr;
        }

        template <typename U>
        void reset(U* p) {
            shared_ptr<U>(p).swap(*this);
        }

        template <typename U, typename Deleter>
        void reset(U* p, Deleter d) {
            shared_ptr<U>(p, d).swap(*this);
        }

        // Swap
        void swap(shared_ptr& other) noexcept {
            T* tmp_ptr = ptr_;
            __shared_ptr_control_block_base* tmp_ctrl = control_block_;
            ptr_ = other.ptr_;
            control_block_ = other.control_block_;
            other.ptr_ = tmp_ptr;
            other.control_block_ = tmp_ctrl;
        }

        // Accessors
        T* get() const noexcept { return ptr_; }
        
        T& operator*() const noexcept {
            return *ptr_;
        }
        
        T* operator->() const noexcept {
            return ptr_;
        }

        T& operator[](size_t i) const noexcept {
            return ptr_[i];
        }

        template <typename D>
        D* get_deleter() const noexcept {
            return nullptr;
        }

        // Reference count
        long use_count() const noexcept {
            return control_block_ ? static_cast<long>(control_block_->use_count()) : 0;
        }

        bool unique() const noexcept { return use_count() == 1; }
        explicit operator bool() const noexcept { return ptr_ != nullptr; }

        // Owner comparison
        template <typename U>
        bool owner_before(const shared_ptr<U>& other) const noexcept {
            return control_block_ < other.control_block_;
        }

        template <typename U>
        bool owner_before(const weak_ptr<U>& other) const noexcept {
            return control_block_ < other.control_block_;
        }

    private:
        void release() {
            if (control_block_) {
                control_block_->release_strong();
            }
        }

        shared_ptr(T* p, __shared_ptr_control_block_base* cb) noexcept : ptr_(p), control_block_(cb) {
            if (control_block_) {
                control_block_->add_strong();
            }
        }

        T* ptr_;
        __shared_ptr_control_block_base* control_block_;

        template <typename U> friend class shared_ptr;
        template <typename U> friend class weak_ptr;
        template <typename U> friend class enable_shared_from_this;
};

// weak_ptr::lock() implementation (after shared_ptr definition)
template <typename T>
shared_ptr<T> weak_ptr<T>::lock() const noexcept {
    if (control_block_ == nullptr || control_block_->expired()) {
        return shared_ptr<T>();
    }
    return shared_ptr<T>(ptr_, control_block_);
}



// Forward declaration
template <typename T> class enable_shared_from_this;

// Forward declaration for helper
template <typename T> class enable_shared_from_this;

// Helper to initialize enable_shared_from_this base class
// This is called from shared_ptr constructor when T inherits from enable_shared_from_this
template <typename T>
void __init_weak_this_impl(const shared_ptr<T>& sp, enable_shared_from_this<T>* base) {
    if (base) {
        base->__init_weak_this(sp);
    }
}



// Non-template base class for enable_shared_from_this
class __enable_shared_from_this_base {
protected:
    virtual ~__enable_shared_from_this_base() {}

    // Virtual function to initialize weak_this_
    virtual void __do_init_weak_this(const void* sp) = 0;

    // Tag type for detection
    typedef void __esft_base_tag;

    // Grant access to shared_ptr
    template <typename U>
    friend class shared_ptr;

    // Grant access to the detection helper
    template <typename U>
    friend struct __is_enable_shared_from_this;

    // Grant access to the init dispatcher
    template <typename U, bool>
    friend struct __esft_init_dispatcher;
};

// enable_shared_from_this definition
template <typename T>
class enable_shared_from_this : public __enable_shared_from_this_base {
public:
    shared_ptr<T> shared_from_this() {
        return shared_ptr<T>(weak_this_);
    }

    shared_ptr<const T> shared_from_this() const {
        return shared_ptr<const T>(weak_this_);
    }

    weak_ptr<T> weak_from_this() noexcept {
        return weak_this_;
    }

    weak_ptr<const T> weak_from_this() const noexcept {
        return weak_this_;
    }

protected:
    enable_shared_from_this() noexcept : weak_this_() {}
    enable_shared_from_this(const enable_shared_from_this&) noexcept : weak_this_() {}
    enable_shared_from_this& operator=(const enable_shared_from_this&) noexcept {
        return *this;
    }
    ~enable_shared_from_this() {}

private:
    mutable weak_ptr<T> weak_this_;

    // Virtual function implementation
    void __do_init_weak_this(const void* sp) override {
        // Use reinterpret_cast because we're casting from void*
        const shared_ptr<T>* sp_ptr = reinterpret_cast<const shared_ptr<T>*>(sp);
        // Only initialize if not already initialized
        if (weak_this_.expired()) {
            weak_this_ = *sp_ptr;
        }
    }

    // Grant access to shared_ptr
    template <typename U>
    friend class shared_ptr;
};

// Helper to detect if T inherits from enable_shared_from_this
template <typename T>
struct __is_enable_shared_from_this {
    template <typename U>
    static char test(typename U::__esft_base_tag*);
    template <typename U>
    static int test(...);
    static const bool value = sizeof(test<T>(nullptr)) == sizeof(char);
};

// Helper struct to dispatch initialization
template <typename T, bool HasESFT = __is_enable_shared_from_this<T>::value>
struct __esft_init_dispatcher;

// Specialization for types WITH enable_shared_from_this
template <typename T>
struct __esft_init_dispatcher<T, true> {
    static void init(const shared_ptr<T>& sp, T* p) {
        if (p) {
            __enable_shared_from_this_base* base = static_cast<__enable_shared_from_this_base*>(p);
            base->__do_init_weak_this(&sp);
        }
    }
};

// Specialization for types WITHOUT enable_shared_from_this
template <typename T>
struct __esft_init_dispatcher<T, false> {
    static void init(const shared_ptr<T>&, T*) {
        // Do nothing
    }
};

// Helper to initialize enable_shared_from_this
template <typename T>
void __try_init_enable_shared_from_this(const shared_ptr<T>& sp, T* p) {
    __esft_init_dispatcher<T>::init(sp, p);
}

// Free functions

// make_unique
template <typename T, typename... Args, typename enable_if<!is_array<T>::value, int>::type = 0>
unique_ptr<T>
make_unique(Args&&... args) {
    return unique_ptr<T>(new T(std::forward<Args>(args)...));
}

template <typename T, typename enable_if<is_array<T>::value, int>::type = 0>
unique_ptr<T>
make_unique(size_t n) {
    typedef typename remove_extent<T>::type element_type;
    return unique_ptr<T>(new element_type[n]());
}

// make_shared
template <typename T, typename... Args>
shared_ptr<T> make_shared(Args&&... args) {
    T* ptr = new T(std::forward<Args>(args)...);
    return shared_ptr<T>(ptr);
}

// swap
template <typename T, typename Deleter>
void swap(unique_ptr<T, Deleter>& a, unique_ptr<T, Deleter>& b) noexcept {
    a.swap(b);
}

template <typename T>
void swap(shared_ptr<T>& a, shared_ptr<T>& b) noexcept {
    a.swap(b);
}

template <typename T>
void swap(weak_ptr<T>& a, weak_ptr<T>& b) noexcept {
    a.swap(b);
}

// Pointer cast functions
template <typename T, typename U>
shared_ptr<T> static_pointer_cast(const shared_ptr<U>& sp) noexcept {
    return shared_ptr<T>(sp, static_cast<T*>(sp.get()));
}

template <typename T, typename U>
shared_ptr<T> dynamic_pointer_cast(const shared_ptr<U>& sp) noexcept {
    T* p = static_cast<T*>(sp.get());
    return shared_ptr<T>(sp, p);
}

template <typename T, typename U>
shared_ptr<T> const_pointer_cast(const shared_ptr<U>& sp) noexcept {
    return shared_ptr<T>(sp, const_cast<T*>(sp.get()));
}

// Comparison operators for shared_ptr
template <typename T, typename U>
bool operator==(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) noexcept {
    return lhs.get() == rhs.get();
}

template <typename T, typename U>
bool operator!=(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) noexcept {
    return !(lhs == rhs);
}

template <typename T, typename U>
bool operator<(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) noexcept {
    return lhs.get() < rhs.get();
}

template <typename T, typename U>
bool operator<=(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) noexcept {
    return !(rhs < lhs);
}

template <typename T, typename U>
bool operator>(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) noexcept {
    return rhs < lhs;
}

template <typename T, typename U>
bool operator>=(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) noexcept {
    return !(lhs < rhs);
}

template <typename T>
bool operator==(const shared_ptr<T>& lhs, nullptr_t) noexcept {
    return !lhs;
}

template <typename T>
bool operator==(nullptr_t, const shared_ptr<T>& rhs) noexcept {
    return !rhs;
}

template <typename T>
bool operator!=(const shared_ptr<T>& lhs, nullptr_t) noexcept {
    return static_cast<bool>(lhs);
}

template <typename T>
bool operator!=(nullptr_t, const shared_ptr<T>& rhs) noexcept {
    return static_cast<bool>(rhs);
}

// Comparison operators for weak_ptr
template <typename T, typename U>
bool operator<(const weak_ptr<T>& lhs, const weak_ptr<U>& rhs) noexcept {
    return lhs.lock() < rhs.lock();
}

// owner_less
template <typename T = void>
struct owner_less;

template <typename T>
struct owner_less<shared_ptr<T>> {
    bool operator()(const shared_ptr<T>& lhs, const shared_ptr<T>& rhs) const noexcept {
        return lhs.owner_before(rhs);
    }
};

template <typename T>
struct owner_less<weak_ptr<T>> {
    bool operator()(const weak_ptr<T>& lhs, const weak_ptr<T>& rhs) const noexcept {
        return lhs.owner_before(rhs);
    }
};

template <>
struct owner_less<void> {
    template <typename T, typename U>
    bool operator()(const shared_ptr<T>& lhs, const shared_ptr<U>& rhs) const noexcept {
        return lhs.owner_before(rhs);
    }

    template <typename T, typename U>
    bool operator()(const weak_ptr<T>& lhs, const weak_ptr<U>& rhs) const noexcept {
        return lhs.owner_before(rhs);
    }

    template <typename T, typename U>
    bool operator()(const shared_ptr<T>& lhs, const weak_ptr<U>& rhs) const noexcept {
        return lhs.owner_before(rhs);
    }

    template <typename T, typename U>
    bool operator()(const weak_ptr<T>& lhs, const shared_ptr<U>& rhs) const noexcept {
        return lhs.owner_before(rhs);
    }

    typedef void is_transparent;
};

// allocator
template <typename T>
class allocator {
    public:
        typedef T value_type;
        typedef T* pointer;
        typedef const T* const_pointer;
        typedef T& reference;
        typedef const T& const_reference;
        typedef size_t size_type;
        typedef ptrdiff_t difference_type;

        allocator() noexcept {}
        allocator(const allocator&) noexcept {}

        template <typename U>
        allocator(const allocator<U>&) noexcept {}

        ~allocator() {}

        pointer allocate(size_type n, const void* = nullptr) {
            return static_cast<pointer>(::operator new(n * sizeof(T)));
        }

        void deallocate(pointer p, size_type) {
            ::operator delete(p);
        }
};

template <typename T, typename U>
bool operator==(const allocator<T>&, const allocator<U>&) noexcept { return true; }

template <typename T, typename U>
bool operator!=(const allocator<T>&, const allocator<U>&) noexcept { return false; }

}

