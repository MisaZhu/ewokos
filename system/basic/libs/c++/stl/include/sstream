template <typename Char>
class basic_stringbuf {
public:
    typedef Char char_type;
    typedef ::std::string string_type;
protected:
    ::std::string str_;
    size_t rpos_;
    size_t wpos_;

public:
    basic_stringbuf() : str_(), rpos_(0), wpos_(0) {}
    basic_stringbuf(const ::std::string& s) : str_(s), rpos_(0), wpos_(s.size()) {}
    ::std::string str() const { return str_; }
    void str(const ::std::string& s) { str_ = s; rpos_ = 0; wpos_ = s.size(); }
    size_t pubseekoff(size_t off, seekdir dir, int which = (int)(in|out)) {
        return seekoff(off, dir, which);
    }
    size_t seekoff(size_t off, seekdir dir, int which = (int)(in|out)) {
        if (which & (int)in) {
            size_t new_pos;
            if (dir == beg) new_pos = off;
            else if (dir == cur) new_pos = rpos_ + off;
            else if (dir == end) new_pos = str_.size() + off;
            else return (size_t)-1;
            if (new_pos > str_.size()) return (size_t)-1;
            rpos_ = new_pos;
        }
        if (which & (int)out) {
            size_t new_pos;
            if (dir == beg) new_pos = off;
            else if (dir == cur) new_pos = wpos_ + off;
            else if (dir == end) new_pos = str_.size() + off;
            else return (size_t)-1;
            if (new_pos > str_.size()) return (size_t)-1;
            wpos_ = new_pos;
        }
        return rpos_;
    }
    size_t pubseekpos(size_t pos, int which = (int)(in|out)) { return seekpos(pos, which); }
    size_t seekpos(size_t pos, int which = (int)(in|out)) {
        if (pos > str_.size()) return (size_t)-1;
        if (which & (int)in) rpos_ = pos;
        if (which & (int)out) wpos_ = pos;
        return pos;
    }
    size_t get_rpos() const { return rpos_; }
    void set_rpos(size_t p) { rpos_ = p; }
    size_t get_wpos() const { return wpos_; }
    void set_wpos(size_t p) { wpos_ = p; }
    const ::std::string& get_str() const { return str_; }
    ::std::string& get_str() { return str_; }
};

template <typename Char>
class basic_istringstream {
public:
    typedef Char char_type;
    typedef int int_type;
    typedef long pos_type;
    typedef long off_type;
    typedef int streamsize;
protected:
    basic_stringbuf<Char> buf_;
    size_t gcount_;
public:
    basic_istringstream() : buf_(), gcount_(0) {}
    basic_istringstream(const ::std::string& s) : buf_(s), gcount_(0) {}
    basic_stringbuf<Char>* rdbuf() { return &buf_; }
    ::std::string str() const { return buf_.str(); }
    void str(const ::std::string& s) { buf_.str(s); }
    int_type get() {
        const ::std::string& s = buf_.get_str();
        size_t pos = buf_.get_rpos();
        if (pos >= s.size()) { gcount_ = 0; return -1; }
        char c = s[pos];
        buf_.set_rpos(pos + 1);
        gcount_ = 1;
        return (int_type)c;
    }
    basic_istringstream& get(char_type& c) {
        int_type ch = get();
        if (ch != -1) c = (char_type)ch;
        return *this;
    }
    basic_istringstream& read(char_type* s, int count) {
        int i = 0;
        for (i = 0; i < count; i++) {
            int_type ch = get();
            if (ch == -1) break;
            s[i] = (char_type)ch;
        }
        return *this;
    }
    basic_istringstream& operator>>(char_type& c) {
        int_type ch = get();
        if (ch != -1) c = (char_type)ch;
        return *this;
    }
    basic_istringstream& operator>>(::std::string& s) {
        s.clear();
        char_type c;
        int ch;
        while (true) {
            ch = get();
            if (ch == -1) return *this;
            c = (char_type)ch;
            if (c != ' ' && c != '\n' && c != '\t') break;
        }
        s.append(1, c);
        while (true) {
            ch = get();
            if (ch == -1) break;
            c = (char_type)ch;
            if (c == ' ' || c == '\n' || c == '\t') break;
            s.append(1, c);
        }
        return *this;
    }
    basic_istringstream& operator>>(int& value) {
        value = 0;
        char_type c = 0;
        bool neg = false;
        bool has_digit = false;
        // Skip leading whitespace
        while (true) {
            int_type ch = get();
            if (ch == -1) return *this;
            c = (char_type)ch;
            if (c != ' ' && c != '\n' && c != '\t' && c != '\r') break;
        }
        // Check for negative sign
        if (c == '-') {
            neg = true;
            int_type ch = get();
            if (ch == -1) {
                if (neg) value = -value;
                return *this;
            }
            c = (char_type)ch;
        }
        // Read digits
        while (true) {
            if (c >= '0' && c <= '9') {
                value = value * 10 + (c - '0');
                has_digit = true;
            } else {
                break;
            }
            int_type ch = get();
            if (ch == -1) break;
            c = (char_type)ch;
        }
        if (neg) value = -value;
        return *this;
    }
    explicit operator bool() const { return buf_.get_rpos() < buf_.get_str().size(); }
    bool eof() const { return buf_.get_rpos() >= buf_.get_str().size(); }
    int gcount() const { return gcount_; }
};

template <typename Char>
class basic_ostringstream {
public:
    typedef Char char_type;
    typedef int int_type;
    typedef long pos_type;
    typedef long off_type;
    typedef int streamsize;
protected:
    basic_stringbuf<Char> buf_;
public:
    basic_ostringstream() : buf_() {}
    basic_ostringstream(const ::std::string& s) : buf_(s) {}
    basic_stringbuf<Char>* rdbuf() { return &buf_; }
    ::std::string str() const { return buf_.str(); }
    void str(const ::std::string& s) { buf_.str(s); }
    basic_ostringstream& put(char_type c) { buf_.get_str() += c; return *this; }
    basic_ostringstream& write(const char_type* s, int count) {
        for (int i = 0; i < count; i++) buf_.get_str() += s[i];
        return *this;
    }
    basic_ostringstream& operator<<(char_type c) { return put(c); }
    basic_ostringstream& operator<<(const char_type* s) {
        while (*s) put(*s++);
        return *this;
    }
    basic_ostringstream& operator<<(const ::std::string& s) {
        for (size_t i = 0; i < s.size(); i++) put(s[i]);
        return *this;
    }
    basic_ostringstream& operator<<(basic_streambuf<Char, std::char_traits<Char>>* sb) {
        if (sb) {
            int_type c;
            while ((c = sb->sbumpc()) != -1) {
                put(static_cast<char_type>(c));
            }
        }
        return *this;
    }
    basic_ostringstream& operator<<(int value) {
        char buf[32]; int len = 0; bool neg = false;
        if (value < 0) { neg = true; value = -value; }
        if (value == 0) buf[len++] = '0';
        else while (value > 0) { buf[len++] = '0' + (value % 10); value /= 10; }
        if (neg) buf[len++] = '-';
        for (int i = len - 1; i >= 0; i--) put(buf[i]);
        return *this;
    }
    basic_ostringstream& operator<<(unsigned int value) {
        char buf[32]; int len = 0;
        if (value == 0) buf[len++] = '0';
        else while (value > 0) { buf[len++] = '0' + (value % 10); value /= 10; }
        for (int i = len - 1; i >= 0; i--) put(buf[i]);
        return *this;
    }
    basic_ostringstream& operator<<(long value) {
        char buf[32]; int len = 0; bool neg = false;
        if (value < 0) { neg = true; value = -value; }
        if (value == 0) buf[len++] = '0';
        else while (value > 0) { buf[len++] = '0' + (value % 10); value /= 10; }
        if (neg) buf[len++] = '-';
        for (int i = len - 1; i >= 0; i--) put(buf[i]);
        return *this;
    }
    basic_ostringstream& operator<<(unsigned long value) {
        char buf[32]; int len = 0;
        if (value == 0) buf[len++] = '0';
        else while (value > 0) { buf[len++] = '0' + (value % 10); value /= 10; }
        for (int i = len - 1; i >= 0; i--) put(buf[i]);
        return *this;
    }
};

