#ifndef EWOK_STL_FUNCTIONAL_H
#define EWOK_STL_FUNCTIONAL_H

namespace std {

// less functor
template <typename T>
struct less {
    bool operator()(const T& a, const T& b) const {
        return a < b;
    }
};

// greater functor
template <typename T>
struct greater {
    bool operator()(const T& a, const T& b) const {
        return a > b;
    }
};

// equal_to functor
template <typename T>
struct equal_to {
    bool operator()(const T& a, const T& b) const {
        return a == b;
    }
};

// not_equal_to functor
template <typename T>
struct not_equal_to {
    bool operator()(const T& a, const T& b) const {
        return a != b;
    }
};

}

#endif // EWOK_STL_FUNCTIONAL_H
