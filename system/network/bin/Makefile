	cd ping; $(MAKE) clean
	cd host; $(MAKE) clean
	cd https_test; $(MAKE) clean
	cd telnet; $(MAKE) clean
	cd ssh; $(MAKE) clean
	cd scp; $(MAKE) clean
	cd sftp-server; $(MAKE) clean
