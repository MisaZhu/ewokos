#ifndef EWOK_STL_MEMORY_H
#define EWOK_STL_MEMORY_H

#include <stddef.h>

namespace std {

template <typename T>
class default_delete {
    public:
        void operator()(T* ptr) const {
            if (ptr) {
                delete ptr;
            }
        }
};

template <typename T>
class default_delete<T[]> {
    public:
        void operator()(T* ptr) const {
            if (ptr) {
                delete[] ptr;
            }
        }
};

template <typename T, typename Deleter = default_delete<T>>
class unique_ptr {
    public:
        typedef T element_type;
        typedef Deleter deleter_type;

        constexpr unique_ptr() noexcept : ptr_(nullptr), deleter_() {}
        constexpr unique_ptr(nullptr_t) noexcept : ptr_(nullptr), deleter_() {}

        explicit unique_ptr(T* p) noexcept : ptr_(p), deleter_() {}
        unique_ptr(T* p, Deleter d) noexcept : ptr_(p), deleter_(d) {}

        ~unique_ptr() {
            if (ptr_) {
                deleter_(ptr_);
            }
        }

        unique_ptr(const unique_ptr&) = delete;
        unique_ptr& operator=(const unique_ptr&) = delete;

        unique_ptr(unique_ptr&& other) noexcept : ptr_(other.ptr_), deleter_(other.deleter_) {
            other.ptr_ = nullptr;
        }

        unique_ptr& operator=(unique_ptr&& other) noexcept {
            if (this != &other) {
                if (ptr_) {
                    deleter_(ptr_);
                }
                ptr_ = other.ptr_;
                deleter_ = other.deleter_;
                other.ptr_ = nullptr;
            }
            return *this;
        }

        T* get() const noexcept { return ptr_; }
        Deleter& get_deleter() noexcept { return deleter_; }
        const Deleter& get_deleter() const noexcept { return deleter_; }

        explicit operator bool() const noexcept { return ptr_ != nullptr; }

        T& operator*() const { return *ptr_; }
        T* operator->() const { return ptr_; }
        T& operator[](size_t i) const { return ptr_[i]; }

        T* release() noexcept {
            T* tmp = ptr_;
            ptr_ = nullptr;
            return tmp;
        }

        void reset(T* p = nullptr) noexcept {
            if (ptr_) {
                deleter_(ptr_);
            }
            ptr_ = p;
        }

        void swap(unique_ptr& other) noexcept {
            T* tmp_ptr = ptr_;
            Deleter tmp_del = deleter_;
            ptr_ = other.ptr_;
            deleter_ = other.deleter_;
            other.ptr_ = tmp_ptr;
            other.deleter_ = tmp_del;
        }

    private:
        T* ptr_;
        Deleter deleter_;
};

