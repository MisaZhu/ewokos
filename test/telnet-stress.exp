#!/usr/bin/expect -f
#
# telnet-stress.exp - Automated telnet stress test for EwokOS in QEMU
#
# Usage:
#   expect telnet-stress.exp [host] [port] [iterations] [timeout]
#
# Defaults:
#   host       127.0.0.1
#   port       2323
#   iterations 10
#   timeout    30 (seconds, per iteration)
#
# Behavior:
#   - telnet to host:port
#   - login as root / root
#   - wait for shell prompt
#   - run `cat /bin/ls | dump` and wait for prompt to return, N times
#   - on timeout/eof, report which iteration hung and exit non-zero
#   - on success, report and exit 0
#

# ---- argument parsing with defaults ----
set host       "127.0.0.1"
set port       2323
set iterations 10
set per_to     30

if {[llength $argv] >= 1} { set host       [lindex $argv 0] }
if {[llength $argv] >= 2} { set port       [lindex $argv 1] }
if {[llength $argv] >= 3} { set iterations [lindex $argv 2] }
if {[llength $argv] >= 4} { set per_to     [lindex $argv 3] }

# Shell prompt regex. ANSI escape codes may be interleaved, so wildcards are
# used generously. Matches e.g. "[telnet:root]:/# ".
set prompt_re {\[telnet:root\]:.+#}

puts "=== EwokOS telnet stress test ==="
puts "host=$host port=$port iterations=$iterations per-iteration-timeout=${per_to}s"

# ---- connect ----
# Use a generous timeout for the initial connect + login handshake.
set timeout 60

spawn telnet $host $port

expect {
    timeout {
        puts "FAIL: timed out waiting for telnet connection to $host:$port"
        exit 2
    }
    eof {
        puts "FAIL: telnet connection to $host:$port closed unexpectedly (eof)"
        exit 2
    }
    -re {(?i)login:} {
        # got login prompt
    }
}

send "root\r"

expect {
    timeout {
        puts "FAIL: timed out waiting for password prompt"
        exit 2
    }
    eof {
        puts "FAIL: connection closed while waiting for password prompt (eof)"
        exit 2
    }
    -re {(?i)password:} {
        # got password prompt
    }
}

send "root\r"

# ---- wait for the first shell prompt ----
expect {
    timeout {
        puts "FAIL: timed out waiting for initial shell prompt after login"
        exit 2
    }
    eof {
        puts "FAIL: connection closed while waiting for shell prompt (eof)"
        exit 2
    }
    -re $prompt_re {
        # logged in, shell ready
    }
}

puts "LOGIN OK: shell prompt detected"

# ---- stress loop ----
for {set i 1} {$i <= $iterations} {incr i} {
    puts "ITERATION $i/$iterations ... START"

    # per-iteration timeout
    set timeout $per_to

    send "cat /bin/ls | dump\r"

    expect {
        timeout {
            puts "ITERATION $i/$iterations ... HUNG (timeout after ${per_to}s)"
            puts "FAIL: iteration $i hung waiting for prompt to return"
            exit 1
        }
        eof {
            puts "ITERATION $i/$iterations ... HUNG (eof/connection closed)"
            puts "FAIL: iteration $i lost connection (eof)"
            exit 1
        }
        -re $prompt_re {
            puts "ITERATION $i/$iterations ... COMPLETED"
        }
    }
}

puts "SUCCESS: all $iterations iterations COMPLETED"

# clean logout attempt (best-effort, do not fail the test on this)
set timeout 5
send "exit\r"
expect {
    timeout {}
    eof {}
}

exit 0
